generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id               String    @id @default(cuid())
  name             String
  companyFullName  String?
  industry         String?
  companyPosition  String?
  mainProducts     String?
  financialData    String?
  orderProgress    String?
  financingPlan    String?
  financingRound   String?
  followStage      String    @default("INITIAL_TALK")
  coreAdvantage    String?
  coreTeam         String?
  competitors      String?
  competitorAnalysisJson String?
  description      String?
  status           String    @default("PENDING")
  totalAmount      String   // 融资金额（用户自填单位，如"500万"、"2亿"）
  raisedAmount     Float     @default(0)
  investmentValuation Float?  // 投资估值（万元）
  targetDate       DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String
  aiCardJson       String?
  keywords         String?
  // 维护人保护期到期时间：创建时 = createdAt + 3个月；接手后重置
  protectionExpiresAt DateTime?
  // 项目经过的所有阶段（JSON 数组字符串，如 ["INITIAL_TALK","PRE_DD"]）
  // 用于累计统计：进入某阶段即+1，变更到后续阶段时补齐中间阶段，不回退
  passedStages String?
  // 最近一次阶段变更时间（用于本周新增项目：本周变更阶段的项目也显示）
  stageChangedAt DateTime?
  investments      Investment[]
  investors        Investor[] @relation("InvestorProjects")
  members          ProjectMember[]
  news             ProjectNews[]
  partnerReviews   PartnerReview[]
  followUpNotes    FollowUpNote[]
  stageApprovals   StageApproval[]
  takeoverRequests TakeoverRequest[]
  stageChangeRequests StageChangeRequest[]
  createdBy        User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([createdById])
  @@index([followStage])
  @@index([targetDate])
  @@index([stageChangedAt])
  @@index([protectionExpiresAt])
  @@index([status])
}

model Investment {
  id          String    @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  investorId  String
  projectId   String
  investor    Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([investorId])
}

model Investor {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  phone       String?
  avatar      String?
  investments Investment[]
  projects    Project[]   @relation("InvestorProjects")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  username      String?         @unique  // 账户名（可用于登录）
  passwordHash  String
  name          String?
  avatar        String?  // 头像 URL（如 /avatars/xxx.png）
  role          String          @default("TEMP_VISITOR")
  status        String          @default("ACTIVE")  // ACTIVE / PENDING / REJECTED / DISABLED
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sessions      Session[]
  projects      Project[]
  projectMembers ProjectMember[]
  partnerReviews   PartnerReview[]
  followUpNotes    FollowUpNote[]
  stageApprovals   StageApproval[]
  projectLeads     ProjectLead[]
  // 接手申请：作为请求者
  takeoverRequestsInitiated TakeoverRequest[] @relation("TakeoverRequestRequester")
  // 接手申请：作为当前维护人（被请求者）
  takeoverRequestsReceived  TakeoverRequest[] @relation("TakeoverRequestOwner")
  // 阶段变更请求：作为发起者
  stageChangeRequestsInitiated StageChangeRequest[] @relation("StageChangeRequestRequester")
  // 阶段变更请求：作为审批者
  stageChangeRequestsReviewed  StageChangeRequest[] @relation("StageChangeRequestReviewer")
}

// 项目线索（用于在新建项目时进行重合检测和合并）
model ProjectLead {
  id               String   @id @default(cuid())
  name             String
  industry         String?  // 行业/赛道
  companyPosition  String?  // 公司定位
  mainProducts     String?  // 主要产品
  financingHistory String?  // 融资经历
  contactInfo      String?  // 联系方式
  description      String?  // 备注
  status           String   @default("PENDING") // PENDING / CONVERTED / ARCHIVED
  createdById      String
  createdBy        User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([name])
  @@index([createdById])
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectNews {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  source         String?
  url            String
  summary        String?
  analysisType   String   @default("UNKNOWN")
  analysisDetail String?
  publishedAt    DateTime
  createdAt      DateTime @default(now())

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, url])
  @@index([projectId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model PartnerReview {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model FollowUpNote {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model StageApproval {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  userName    String
  status      String   // APPROVED / REJECTED
  comment     String?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
}

// 项目接手申请
// - 3个月保护期内：status=PENDING 等待原维护人审批
// - 3个月保护期外：status=AUTO_COMPLETED 直接变更维护人
model TakeoverRequest {
  id              String   @id @default(cuid())
  projectId       String
  requesterId     String   // 发起接手的用户
  currentOwnerId  String   // 当前维护人
  status          String   @default("PENDING") // PENDING / APPROVED / REJECTED / AUTO_COMPLETED
  comment         String?  // 请求者留言
  reviewerComment String?  // 审批人留言
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reviewedAt      DateTime? // 审批时间

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester       User     @relation("TakeoverRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  currentOwner    User     @relation("TakeoverRequestOwner", fields: [currentOwnerId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([requesterId])
  @@index([currentOwnerId])
  @@index([status])
}

// 阶段变更请求（需投资合伙人审批）
// 仅以下两种变更需审批：
// 1. 从 INITIAL_TALK 或 PRE_DD → PROJECT_INITIATION（立项）
// 2. 从 DUE_DILIGENCE → CLOSING（交割）
model StageChangeRequest {
  id          String   @id @default(cuid())
  projectId   String
  requesterId String   // 发起阶段变更的维护人
  reviewerId  String?  // 审批的投资合伙人
  fromStage   String   // 变更前阶段
  toStage     String   // 变更后阶段
  status      String   @default("PENDING") // PENDING / APPROVED / REJECTED
  comment     String?  // 发起者留言
  reviewerComment String? // 审批者留言
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester   User     @relation("StageChangeRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer    User?    @relation("StageChangeRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([requesterId])
}

// 新闻监控：融资新闻文章
model NewsArticle {
  id          String   @id @default(cuid())
  title       String   // 文章标题
  source      String   // 来源（如 36氪、投资界、量子位等）
  sourceUrl   String?  // 原文链接
  industry    String   // 所属行业赛道
  summary     String   // 摘要（卡片展示用）
  content     String   // 详细内容
  author      String?  // 作者
  publishedAt DateTime // 发布时间
  weekStart   DateTime // 所属周的开始时间（周一12:00），用于按周筛选
  createdAt   DateTime @default(now())

  @@index([industry])
  @@index([publishedAt])
  @@index([weekStart])
  @@index([source])
}
