# 数据库连接（PostgreSQL）
# 本地开发：postgresql://user:password@localhost:5432/investrack
# 腾讯云生产：postgresql://user:password@tg-db-postgres.sql.tencentcdb.com:port/dbname
DATABASE_URL="postgresql://user:password@localhost:5432/investrack"

# NextAuth 配置
# 生成强随机密钥：openssl rand -base64 32
NEXTAUTH_SECRET=""

# 生产环境设为实际 HTTPS 域名，如 https://investrask.example.com
NEXTAUTH_URL="http://localhost:3000"

# DeepSeek API Key（融资热点分析、新闻监控、竞争态势分析）
DEEPSEEK_API_KEY=""

# 腾讯云 COS 配置（头像上传，可选；不配置则回退到本地 public/avatars/）
# COS_SECRET_ID=""
# COS_SECRET_KEY=""
# COS_BUCKET=""
# COS_REGION="ap-guangzhou"
